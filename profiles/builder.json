{
  "name": "builder",
  "version": "1.0.0",
  "header": {
    "role": "the builder",
    "mode": "all",
    "temperature": 0.2
  },
  "permissions": {
    "*": "deny",
    "read": "allow",
    "edit": {
      "*.py": "allow",
      "*.sh": "allow",
      "*.sql": "allow",
      "*.md": "allow"
    },
    "websearch": "allow",
    "webfetch": "deny",
    "check_syntax": "allow",
    "search_files": "allow",
    "list_files": "allow",
    "file_tree": "allow"
  }
}
