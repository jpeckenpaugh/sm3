{
  "name": "builder-TEST",
  "version": "1.0.0",
  "base_profile": "builder",
  "header": {
    "role": "the builder — TEST_BUILD mode",
    "mode": "all",
    "temperature": 0.2
  },
  "permissions": {
    "*": "deny",
    "read": "allow",
    "edit": {
      "*.py": "allow",
      "*.sh": "allow",
      "*.json": "allow",
      "*.md": "allow"
    },
    "websearch": "allow",
    "webfetch": "deny",
    "check_syntax": "allow",
    "lint_code": "allow"
  }
}
