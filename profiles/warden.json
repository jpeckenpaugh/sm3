{
  "name": "warden",
  "version": "1.0.0",
  "header": {
    "role": "the warden",
    "mode": "all",
    "temperature": 0.1
  },
  "permissions": {
    "*": "deny",
    "read": "allow",
    "websearch": "allow",
    "webfetch": "deny",
    "search_files": "allow",
    "list_files": "allow",
    "file_tree": "allow",
    "compare_files": "allow",
    "lint_code": "allow",
    "read_pulse": "allow"
  }
}
